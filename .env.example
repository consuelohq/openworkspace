PORT=8850
MCP_SERVER_NAME=openworkspace
WORKSPACE_DIR=/absolute/path/to/your/repo

# steering
STEERING_FILE=/absolute/path/to/your/STEERING.md
REPO_TREE_FILE=

# github
GITHUB_TOKEN=
GITHUB_REPO=owner/repo
REPO_NAME=owner/repo

# memory backend
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-service-role-key
NVIDIA_API_KEY=
EMBEDDING_MODEL=nvidia/nv-embedqa-e5-v5

# optional chat export sources
CHAT_EXPORT_KIRO_DIR=
CHAT_EXPORT_OPENCODE_DIR=

# optional slack integration
SLACK_WEBHOOK_URL=

# optional tracing
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=openworkspace
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# optional externally visible hostname
MCP_SERVER_URL=

# oauth (for chatgpt connector authentication)
OAUTH_CLIENT_ID=openworkspace
OAUTH_CLIENT_SECRET=generate-a-random-secret-here
